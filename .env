# ============================================================
#  Wedding Card – Configuration
#  Edit these values, then restart `npm run dev`.
#  All variables must start with VITE_ to be exposed to React.
# ============================================================

# ── Couple ──────────────────────────────────────────────────
VITE_GROOM_NAME=Quốc Tuấn
VITE_BRIDE_NAME=Ái Kiều

# ── Wedding date ────────────────────────────────────────────
# ISO format used for the countdown timer
VITE_WEDDING_DATE=2026-04-26T11:00:00
# Long display string shown in the hero banner
VITE_WEDDING_DATE_DISPLAY=Chủ Nhật, ngày 26 tháng 04 năm 2026
# Short display string shown in the footer
VITE_WEDDING_DATE_SHORT=26 · 04 · 2026

# ── Hashtag & city ──────────────────────────────────────────
VITE_HASHTAG=TuấnKiều2026
VITE_CITY=Đắk Lắk
# ── Tiệc Cúng Ông Bà (separate date, before the wedding) ───
VITE_CUNG_ONG_BA_DATE_DISPLAY=Thứ Bảy, ngày 25 tháng 04 năm 2026

# ── Bride's family home (Tiệc Cúng Ông Bà) ─────────────────
VITE_BRIDE_HOME_ADDRESS=tại Tư Gia số 108 thôn Tiến Phát
VITE_BRIDE_HOME_MAP=https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d1500!2d108.0751436!3d12.8115249!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2z0KHhu5EgMTA4IMSR4bDhu51uZyBz4buRIDQsIFF14bqjbmcgUGjDuiwgQ8awIE0nZ2FyLCDEkOG6r2sgTOG6r2s!5e0!3m2!1svi!2svn
VITE_BRIDE_HOME_MAP_LINK=https://www.google.com/maps/search/12.8115249,108.0751436

# ── Restaurant (ceremony & reception) ───────────────────────
VITE_RESTAURANT_NAME=Nhà Nghỉ Tấn Chương Và Nhà Hàng Tiệc Cưới
VITE_RESTAURANT_ADDRESS=
VITE_RESTAURANT_MAP=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1500!2d108.0783508!3d12.8158311!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3171ff55fc36115b%3A0x3176cb08e8a452b3!2zTmjDoCBOZ2jhu4kgVOG6pW4gQ2jGsMahbmcgVsOgIE5ow6AgSMOgbmcgVGnhu4djIEPGsOG7m2k!5e0!3m2!1svi!2svn
VITE_RESTAURANT_MAP_LINK=https://www.google.com/maps/search/12.8158311,108.0783508


# ── Event start times ───────────────────────────────────────
VITE_TIME_VU_QUY=17:00 CH
VITE_TIME_CEREMONY=11:00 SA
VITE_TIME_RECEPTION=17:00 CH
